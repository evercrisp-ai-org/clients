{
  "template_id": "body_text",
  "template_name": "Body Text Content Page",
  "template_version": "1.0",
  "page_type": "content",
  "description": "Primary content page with section header, subheader, and multi-paragraph body text for narrative content",
  
  "dimensions": {
    "width": 816,
    "height": 1056,
    "unit": "px"
  },
  
  "background": {
    "type": "solid",
    "color": "$colors.neutral_light"
  },
  
  "elements": [
    {
      "id": "section_header",
      "type": "text",
      "content": "{{section_header}}",
      "font": "$typography.heading.family",
      "font_weight": 500,
      "font_size": 40,
      "color": "$colors.primary.hex",
      "position": { "x": 80, "y": 60 },
      "max_width": 656,
      "line_height": 1.2,
      "description": "Main section heading in Playfair Display"
    },
    {
      "id": "section_subheader",
      "type": "text",
      "content": "{{section_subheader}}",
      "font": "$typography.body.family",
      "font_weight": 500,
      "font_size": 17,
      "color": "$colors.accent.hex",
      "position": { "x": 80, "y": 115 },
      "max_width": 656,
      "line_height": 1.4,
      "description": "Subheader or section context in gold accent"
    },
    {
      "id": "body_text",
      "type": "text",
      "content": "{{body_text}}",
      "font": "$typography.body.family",
      "font_weight": 400,
      "font_size": 16,
      "color": "$colors.neutral_dark.hex",
      "position": { "x": 80, "y": 155 },
      "max_width": 656,
      "max_height": 500,
      "line_height": 1.7,
      "description": "Main body text content - can contain multiple paragraphs. max_height prevents overflow into callout area."
    },
    {
      "id": "callout_box",
      "type": "rectangle",
      "position": { "x": 80, "y": 700 },
      "size": { "width": 656, "height": 100 },
      "background": "$colors.secondary.hex",
      "border_radius": 4,
      "visible": "{{has_callout}}",
      "description": "Optional callout box for key statistics or highlights"
    },
    {
      "id": "callout_text",
      "type": "text",
      "content": "{{callout_text}}",
      "font": "$typography.body.family",
      "font_weight": 500,
      "font_size": 16,
      "color": "#FFFFFF",
      "position": { "x": 100, "y": 725 },
      "max_width": 616,
      "line_height": 1.4,
      "visible": "{{has_callout}}",
      "description": "Text inside callout box"
    },
    {
      "id": "sidebar_accent",
      "type": "rectangle",
      "position": { "x": 0, "y": 0 },
      "size": { "width": 6, "height": 1056 },
      "background": "$colors.accent.hex",
      "description": "Subtle gold accent bar on left edge"
    },
    {
      "id": "footer",
      "type": "component",
      "source": "components/footer.json",
      "position": { "x": 0, "y": 1010 }
    }
  ],
  
  "variables": {
    "section_header": {
      "type": "string",
      "required": true,
      "max_length": 80,
      "description": "Main section heading"
    },
    "section_subheader": {
      "type": "string",
      "required": false,
      "max_length": 150,
      "description": "Optional subheading or section context"
    },
    "body_text": {
      "type": "string",
      "required": true,
      "max_length": 2000,
      "description": "Main body content - paragraphs separated by \\n\\n"
    },
    "has_callout": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Whether to show the callout box"
    },
    "callout_text": {
      "type": "string",
      "required": false,
      "max_length": 200,
      "description": "Key statistic or highlight for callout box"
    },
    "article_name": {
      "type": "string",
      "required": true
    },
    "page_number": {
      "type": "number",
      "required": true
    }
  },
  
  "usage_notes": [
    "Use for narrative content sections like 'The Problem' or strategy explanations",
    "Body text supports multiple paragraphs separated by double newlines",
    "Callout box is optional - use for key statistics or important highlights",
    "Gold accent bar provides visual continuity with brand"
  ]
}
